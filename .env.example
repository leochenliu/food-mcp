# MINIMAX_API_KEY: Required for MiniMax AI API calls (model: MiniMax-M3).
# Endpoint domain is api.minimaxi.com (NOT minimax.io).
# Get your key from the MiniMax platform: 账户管理 > 接口密钥.
MINIMAX_API_KEY="MY_MINIMAX_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# MCP_REMOTE_URL: The deployed Cloudflare Worker MCP endpoint (remote transaction backend).
# Defaults to the public demo worker if unset.
MCP_REMOTE_URL="https://mcd-mcp-server.leochenliu.workers.dev/mcp"

# USE_REMOTE_MCP: Set to "false" to force in-process local MCP execution instead of
# calling the remote Cloudflare Worker. Leave as "true" (or unset) to use the cloud MCP.
USE_REMOTE_MCP="true"
